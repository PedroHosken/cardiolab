// Cardiolab Trials - Prisma Schema
// Modulo de faturamento de pesquisa clinica

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS (representados como String em SQLite, com validacao na aplicacao)
// =============================================================================
// BudgetItemKind:    VISIT | SCREEN_FAIL | PHONE | VIRTUAL | HOME | UNSCHEDULED
//                    | START_UP | CLOSE_OUT | PASS_THROUGH | CRF_TRIGGERED
//                    | SUBSTUDY | PHARMACY | OTHER
// BudgetMethod:      PER_OCCURRENCE | AMOUNT | QUANTITY | AS_INCURRED
// SubjectStatus:     SCREENING | SCREEN_FAIL | RANDOMIZED | ACTIVE | DISCONTINUED | COMPLETED
// VisitStatus:       SCHEDULED | COMPLETED | MISSED | CANCELLED
// LineStatus:        DRAFT | READY | IN_BATCH | INVOICED | PAID | HELD | GLOSSED | WRITTEN_OFF
// BatchStatus:       DRAFT | SUBMITTED | PARTIALLY_PAID | PAID | DISPUTED | CANCELLED

// =============================================================================
// ORGANIZACOES
// =============================================================================

model Sponsor {
  id        String   @id @default(cuid())
  name      String
  country   String?
  notes     String?
  studies   Study[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cro {
  id        String   @id @default(cuid())
  name      String
  country   String?
  studies   Study[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// PESQUISA / ESTUDO
// =============================================================================

model Study {
  id              String   @id @default(cuid())
  protocolNumber  String   @unique
  title           String
  shortTitle      String?
  phase           String?
  therapeuticArea String?
  status          String   @default("ACTIVE") // PLANNING | ACTIVE | ON_HOLD | CLOSED
  defaultCurrency String   @default("USD")

  // codigo de registro de pacientes (prefixo comum + sequencia crescente)
  subjectCodePrefix     String @default("") // ex.: "1378-0020-" (geralmente igual ao protocolo + separador)
  subjectCodeNextNumber Int    @default(1)  // proximo numero a atribuir (001, 002, ...)
  subjectCodePadLength  Int    @default(3)   // digitos com zero a esquerda (min 1, max 15 na UI)

  // wizard de configuracao (estilo Google Ads)
  wizardStep      Int      @default(1)  // 1..6 (6 = pronto para ativar)
  wizardCompleted Boolean  @default(false)

  sponsorId String?
  sponsor   Sponsor? @relation(fields: [sponsorId], references: [id])

  croId String?
  cro   Cro?    @relation(fields: [croId], references: [id])

  contractVersions ContractVersion[]
  subjects         Subject[]
  batches          Batch[]
  visitTemplates   VisitTemplate[]
  checklistItems   StudyChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// CHECKLIST DE NEGOCIACAO POR ESTUDO (instancia editavel do template)
// =============================================================================

model StudyChecklistItem {
  id          String  @id @default(cuid())
  category    String  // ex.: "A) Clausulas contratuais"
  label       String
  status      String  @default("PENDING") // PENDING | IN_PROGRESS | DONE | NOT_APPLICABLE
  notes       String?
  orderIndex  Int     @default(0)

  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studyId])
}

// =============================================================================
// CONTRATO E EMENDAS (versionado)
// =============================================================================

model ContractVersion {
  id              String   @id @default(cuid())
  versionLabel    String   // "v1", "v2 (Amendment 1)", etc.
  effectiveDate   DateTime
  endDate         DateTime?
  currency        String   @default("USD")
  overheadPercent Float    @default(0)        // overhead embutido (ex.: 35)
  holdbackPercent Float    @default(0)        // ex.: 10
  paymentTerms    String?                     // free text inicial
  notes           String?
  isActive        Boolean  @default(true)

  // pagamentos: frequencia + data inicial (referencia para alertas)
  paymentFrequency String?  // MONTHLY | BIMONTHLY | QUARTERLY | QUADRIMONTHLY | SEMIANNUAL | ANNUAL
  paymentStartDate DateTime?

  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  budgetItems BudgetItem[]
  adjustments ContractAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// REAJUSTES DO CONTRATO (anual/renegociacao) - aplicados a partir de uma data
// =============================================================================
// kind: ANNUAL_INDEX (multiplicador aplicado a TODOS os itens)
//      | RENEGOTIATION (preco novo por item, ver BudgetItemPrice)
model ContractAdjustment {
  id            String   @id @default(cuid())
  contractVersionId String
  contractVersion   ContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)

  kind          String   // ANNUAL_INDEX | RENEGOTIATION
  effectiveFrom DateTime
  indexLabel    String?  // ex.: "IPCA 2026", "IGPM"
  multiplier    Float?   // ex.: 1.0438 (4,38%) - usado quando kind=ANNUAL_INDEX
  notes         String?

  itemPrices BudgetItemPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractVersionId, effectiveFrom])
}

// =============================================================================
// HISTORICO DE PRECOS POR ITEM (preco vigente por data)
// =============================================================================
model BudgetItemPrice {
  id            String   @id @default(cuid())
  budgetItemId  String
  budgetItem    BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  effectiveFrom DateTime
  unitAmount    Float
  reason        String?  // texto livre (ex.: "Reajuste IPCA 2026", "Renegociacao Amend2")
  reasonKind    String   @default("INITIAL") // INITIAL | ANNUAL_INDEX | RENEGOTIATION | MANUAL

  adjustmentId  String?
  adjustment    ContractAdjustment? @relation(fields: [adjustmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([budgetItemId, effectiveFrom])
}

// =============================================================================
// CATALOGO DE ITENS FATURAVEIS
// =============================================================================

model BudgetItem {
  id          String  @id @default(cuid())
  code        String? // codigo opcional do sponsor
  name        String
  description String?

  kind   String // BudgetItemKind
  method String // BudgetMethod

  unitAmount      Float   // valor unitario (ja com overhead, conforme CTA)
  defaultQuantity Float   @default(1)
  currency        String  @default("USD")

  // gatilho
  autoTrigger Boolean @default(false) // se gera automatico via evento
  requiresInvoice Boolean @default(false) // pass-through (precisa anexo)

  // se true, item esta vinculado a visitas (a relacao real esta em BudgetItemVisit, configurada na pagina da visita)
  // se false, item e "fora de visita" (start-up, close-out, pass-through, etc.) e e tratado em passo proprio
  boundToVisit Boolean @default(true)

  // se true, item se aplica a todas as visitas atuais e futuras do estudo
  appliesToAllVisits Boolean @default(false)

  // visita "primaria" vinculada - mantido para compat e atalho de exibicao
  visitTemplateId String?
  visitTemplate   VisitTemplate? @relation(fields: [visitTemplateId], references: [id])

  // multi-visit: item pode estar vinculado a varias visitas
  visits BudgetItemVisit[]

  contractVersionId String
  contractVersion   ContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)

  billableLines BillableLine[]
  prices        BudgetItemPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// JOIN: BudgetItem <-> VisitTemplate (multi-visit)
// =============================================================================

model BudgetItemVisit {
  budgetItemId    String
  budgetItem      BudgetItem    @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  visitTemplateId String
  visitTemplate   VisitTemplate @relation(fields: [visitTemplateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([budgetItemId, visitTemplateId])
  @@index([visitTemplateId])
}

// =============================================================================
// CRONOGRAMA DE VISITAS DO PROTOCOLO
// =============================================================================

model VisitTemplate {
  id          String  @id @default(cuid())
  code        String  // codigo de visita (ex.: V1, V2/W1, EoT, FU)
  name        String
  visitKind   String  @default("FOLLOWUP") // SCREENING | RANDOMIZATION | FOLLOWUP
  weekOffset  Int?    // legado - mantido para nao quebrar dados antigos
  dayOffset   Int?    // dias contados a partir da randomizacao (negativo = triagem; 0 = randomizacao; positivo = seguimento)
  isPhone     Boolean @default(false)
  isVirtual   Boolean @default(false)
  isHome      Boolean @default(false)
  windowDays      Int? // janela +/- N dias (substitui windowMinus/Plus)
  windowMinusDays Int? // legado
  windowPlusDays  Int? // legado
  orderIndex  Int     @default(0)

  // campos opcionais (JSON em texto — SQLite)
  optionalFieldDefs String @default("[]")

  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  budgetItems       BudgetItem[]
  budgetItemLinks   BudgetItemVisit[]
  subjectVisits     SubjectVisit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// PARTICIPANTES DA PESQUISA
// =============================================================================

model Subject {
  id          String    @id @default(cuid())
  subjectCode String    // ex.: 1076014-001
  status      String    @default("SCREENING") // SubjectStatus
  enrolledAt  DateTime?
  randomizedAt DateTime?
  exitedAt    DateTime?
  notes       String?

  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  visits        SubjectVisit[]
  billableLines BillableLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studyId, subjectCode])
}

model SubjectVisit {
  id          String   @id @default(cuid())
  visitDate   DateTime?
  status      String   @default("SCHEDULED") // VisitStatus
  notes       String?

  // valores dos opcionais (JSON em texto — SQLite)
  optionalValues String @default("{}")

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  visitTemplateId String
  visitTemplate   VisitTemplate @relation(fields: [visitTemplateId], references: [id])

  billableLines BillableLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// LINHA FATURAVEL (motor financeiro)
// =============================================================================

model BillableLine {
  id           String   @id @default(cuid())
  occurredAt   DateTime
  description  String?
  quantity     Float    @default(1)
  grossAmount  Float    // bruto antes de holdback
  holdbackAmount Float  @default(0)
  netAmount    Float    // bruto - holdback
  currency     String   @default("USD")
  status       String   @default("DRAFT") // LineStatus
  holdReason   String?
  invoiceRef   String?  // referencia da NF/recibo (pass-through)

  budgetItemId String
  budgetItem   BudgetItem @relation(fields: [budgetItemId], references: [id])

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  subjectVisitId String?
  subjectVisit   SubjectVisit? @relation(fields: [subjectVisitId], references: [id])

  batchId String?
  batch   Batch?  @relation(fields: [batchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// LOTE DE FATURAMENTO (Batch)
// =============================================================================

model Batch {
  id            String    @id @default(cuid())
  batchNumber   String    @unique // ex.: 2025-08-001
  referenceMonth String?           // ex.: "2025-08"
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  paidDate      DateTime?
  totalGross    Float     @default(0)
  totalHoldback Float     @default(0)
  totalNet      Float     @default(0)
  totalPaid     Float     @default(0)
  currency      String    @default("USD")
  status        String    @default("DRAFT") // BatchStatus
  notes         String?

  studyId String
  study   Study  @relation(fields: [studyId], references: [id])

  billableLines BillableLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// AUDITORIA (append-only)
// =============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  entity    String   // ex.: "BillableLine"
  entityId  String
  action    String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | BATCH_PAY
  actor     String?  // usuario (quando houver auth)
  before    String?  // JSON
  after     String?  // JSON
  notes     String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}
